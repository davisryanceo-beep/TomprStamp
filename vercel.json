{
    "name": "poscafesystem",
    "redirects": [
        {
            "source": "/stamp",
            "destination": "https://tompr-stamp.vercel.app/",
            "permanent": false
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}